{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "message-website-scheduler",
  "main": "src/index.mjs",
  "compatibility_date": "2026-05-27",
  "workers_dev": false,
  "triggers": {
    "crons": ["0 0 * * *", "30 0 * * *", "0 11 * * *", "30 11 * * *", "0 1 * * 1"]
  },
  "observability": {
    "enabled": true
  }
}
